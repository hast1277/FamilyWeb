        <a class="navbar-brand text-white" href="/">Gullberg Family</a>
        <a class="navbar-brand text-white" href="/persons">Personer</a>
        <AuthorizeView>
            <Authorized>
                <span class="text-white me-2">@context.User.Identity?.Name</span>
