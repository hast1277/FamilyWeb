@page "/tree"
@page "/tree/{RootId:long}"

@using DataSetService
@using DataSetService.FamilyTree
@using DataSetService.Models
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.Extensions.Caching.Memory
@using System.Globalization
@implements IAsyncDisposable
@inject NavigationManager Navigation
@inject PersonService PersonService
@inject FamilyTreeService FamilyTreeService
@inject IMemoryCache Cache
@inject IJSRuntime JS

<h3>Familjeträd</h3>

<div class="mb-3 d-flex flex-wrap align-items-end gap-2">
    <div style="min-width: 280px;">
        <label class="form-label">Rotperson</label>
        <InputSelect class="form-select" @bind-Value="selectedRootId">
            @if (persons is not null)
            {
                @foreach (var p in persons)
                {
                    <option value="@p.Id">@p.SurName @p.FirstName (@p.Id)</option>
                }
            }
        </InputSelect>
    </div>
    <button class="btn btn-primary" @onclick="ShowTree">Visa</button>
    <div style="min-width: 220px;">
        <label class="form-label">Textstorlek (PDF): <strong>@(Math.Round(pdfScaleFactor * 100))%</strong></label>
        <input type="range" class="form-range" min="0.5" max="2" step="0.1" 
               value="@pdfScaleFactor.ToString("F1", CultureInfo.InvariantCulture)" 
               @oninput="OnScaleFactorChanged" />
    </div>
    <div style="min-width: 220px;">
        <label class="form-label">Sidorientering (PDF)</label>
        <select class="form-select" value="@pdfOrientation" @onchange="OnOrientationChanged">
            <option value="landscape">Liggande</option>
            <option value="portrait">Stående</option>
        </select>
    </div>
    <div class="text-muted" style="min-width: 220px;">
        A4-sidor: <strong>@(estimatedPageCount?.ToString() ?? "-")</strong>
    </div>
    <button class="btn btn-outline-secondary" @onclick="ExportPdf" disabled="@(lastBuiltRootId is null)">
        ⬇ Spara som PDF
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

<div id="cy-container" class="family-tree-container"></div>

@code {
    [Parameter] public long RootId { get; set; }

    private List<Person>? persons;
    private long selectedRootId;
    private string? error;
    private long? lastBuiltRootId;
    private double pdfScaleFactor = 1.0;
    private string pdfOrientation = "landscape";
    private int? estimatedPageCount;

    private DotNetObjectReference<FamilyTree>? dotNetRef;

    protected override void OnInitialized()
    {
        dotNetRef = DotNetObjectReference.Create(this);
    }

    protected override Task OnInitializedAsync()
    {
        persons = PersonService.GetAllPersons();
        persons = persons.OrderBy(p => p.SurName).ThenBy(p => p.FirstName).ThenBy(p => p.Id).ToList();

        if (selectedRootId <= 0)
            selectedRootId = RootId > 0 ? RootId : (persons.FirstOrDefault()?.Id ?? 0);

        return Task.CompletedTask;
    }

    protected override void OnParametersSet()
    {
        if (RootId > 0)
            selectedRootId = RootId;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (selectedRootId > 0 && lastBuiltRootId != selectedRootId)
            await BuildDiagramAsync(selectedRootId);
    }

    private void ShowTree()
    {
        if (selectedRootId <= 0)
            return;

        Navigation.NavigateTo($"/tree/{selectedRootId}");
    }

    private async Task BuildDiagramAsync(long rootId)
    {
        error = null;

        var buildOptions = new FamilyTreeBuildOptions
        {
            MaxDepth = 6,
            MaxNodes = 150,
            OnlyExpandChildrenWithFamilies = true
        };

        var layoutOptions = new FamilyTreeLayoutOptions
        {
            RowSpacing = 140,
            ColSpacing = 220,
            SpouseSpacing = 180,
            SiblingGapSlots = 1
        };

        var cacheKey = $"family-tree:{rootId}:d{buildOptions.MaxDepth}:n{buildOptions.MaxNodes}:only{buildOptions.OnlyExpandChildrenWithFamilies}:rs{layoutOptions.RowSpacing}:cs{layoutOptions.ColSpacing}:ss{layoutOptions.SpouseSpacing}:gap{layoutOptions.SiblingGapSlots}";

        FamilyTreeDto tree;
        try
        {
            tree = Cache.GetOrCreate(cacheKey, entry =>
            {
                entry.SlidingExpiration = TimeSpan.FromMinutes(2);
                entry.AbsoluteExpirationRelativeToNow = TimeSpan.FromMinutes(10);
                return FamilyTreeService.BuildTree(rootId, buildOptions, layoutOptions);
            })!;
        }
        catch (Exception ex)
        {
            error = ex.Message;
            StateHasChanged();
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("familyTree.init", dotNetRef, "cy-container", tree.Nodes, tree.Edges);
            lastBuiltRootId = rootId;
            await UpdatePageEstimateAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void OnPersonClicked(long personId)
    {
        Navigation.NavigateTo($"/persons/{personId}");
    }

    private async Task ExportPdf()
    {
        await JS.InvokeVoidAsync("familyTree.exportToPdf", pdfScaleFactor, pdfOrientation);
    }

    private async Task OnScaleFactorChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (double.TryParse(value, NumberStyles.Float, CultureInfo.InvariantCulture, out var newValue) ||
            double.TryParse(value, NumberStyles.Float, CultureInfo.CurrentCulture, out newValue))
        {
            pdfScaleFactor = newValue;
            await UpdatePageEstimateAsync();
        }
    }

    private async Task OnOrientationChanged(ChangeEventArgs e)
    {
        pdfOrientation = e.Value?.ToString() == "portrait" ? "portrait" : "landscape";
        await UpdatePageEstimateAsync();
    }

    private async Task UpdatePageEstimateAsync()
    {
        if (lastBuiltRootId is null)
        {
            estimatedPageCount = null;
            return;
        }

        estimatedPageCount = await JS.InvokeAsync<int>("familyTree.getEstimatedPageCount", pdfScaleFactor, pdfOrientation);
        StateHasChanged();
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("familyTree.destroy");
        }
        catch { /* JS runtime may already be disposed on circuit teardown */ }

        dotNetRef?.Dispose();
    }
}