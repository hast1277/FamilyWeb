@page "/persons/{Id:long}"
@inherits ComponentBase
@using DataSetService
@using DataSetService.Models
@inject PersonService PersonService

@if (!loaded)
{
    <p><em>Laddar...</em></p>
}
else if (person == null)
{
    <p>Person hittades inte.</p>
}
else
{
    <div class="person-details">
        <div class="card">
            <div class="person-header">
                <img src="@GetPhotoUrl(person)" alt="@GetPhotoAltText(person)" class="person-photo"
                     onerror="this.onerror=null; this.src='@PlaceholderPhotoPath'" />

                <div class="person-name">
                    <h4>@person.SurName</h4>
                    <h4>@person.FirstName</h4>
                </div>
            </div>

            <table class="table table-borderless person-info">
                <tbody>
                    <tr>
                        <td><strong>Kön</strong></td>
                        <td>@person.Sex</td>
                    </tr>
                    <tr>
                        <td><strong>Född</strong></td>
                        <td>@person.Birthday</td>
                    </tr>
                    <tr>
                        @if (baptism != null)
                        {
                            <td><strong>Döpt</strong></td>
                            <td>@baptism.BaptismDate</td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>

        @if (!string.IsNullOrWhiteSpace(person.Notes))
        {
            <textarea rows="4" cols="83" readonly>@person.Notes</textarea>
        }
    </div>
}
