@page "/"
@namespace FamilyWebBlazorServer.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <base href="/" />
  <title>FamilyWebBlazorServer</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link href="/css/site.css" rel="stylesheet" />


</head>
<body style="background-image: url('/images/family_tree.jpg'); background-size: cover; background-position: center; background-attachment: fixed; min-height: 100vh;">
  <app>
    <component type="typeof(App)" render-mode="ServerPrerendered" />
  </app>

  <script src="https://cdn.jsdelivr.net/npm/cytoscape@3.30.2/dist/cytoscape.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
  <script src="/js/familytree.js"></script>
  <script src="/_framework/blazor.server.js"></script>
</body>
</html>
