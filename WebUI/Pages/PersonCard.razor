@page "/persons/{Id:long}"
@inherits ComponentBase
@using DataSetService
@using DataSetService.Models
@using Microsoft.AspNetCore.Components.Forms
@inject PersonService PersonService

@if (!loaded)
{
    <p><em>Laddar...</em></p>
}
else if (person == null)
{
    <p>Person hittades inte.</p>
}
else
{
    <div class="person-details">
        <div class="card">
            <div class="person-header">
                <div class="person-photo-section">
                    <img src="@GetPhotoUrl(person)" alt="@GetPhotoAltText(person)" class="person-photo"
                         onerror="this.onerror=null; this.src='@PlaceholderPhotoPath'" />

                    <label class="photo-upload-button @(isUploading ? "disabled" : string.Empty)" for="person-photo-upload">
                        @(isUploading ? "Laddar upp..." : "Byt foto")
                    </label>
                    <InputFile id="person-photo-upload"
                               OnChange="OnPhotoSelectedAsync"
                               accept="image/png,image/jpeg,image/webp,image/gif"
                               class="person-photo-input" />

                    @if (!string.IsNullOrWhiteSpace(photoUploadMessage))
                    {
                        <p class="photo-upload-status">@photoUploadMessage</p>
                    }
                </div>

                <div class="person-name">
                    <h4>@person.SurName</h4>
                    <h4>@person.FirstName</h4>
                </div>
            </div>

            <table class="table table-borderless person-info">
                <tbody>
                    <tr>
                        <td><strong>Kön</strong></td>
                        <td>@person.Sex</td>
                    </tr>
                    <tr>
                        <td><strong>Född</strong></td>
                        <td>@(string.IsNullOrWhiteSpace(person.Birthday) ? null : $"* {person.Birthday}")</td>
                    </tr>
                    @if (!string.IsNullOrWhiteSpace(person.DeathDate))
                    {
                        <tr>
                            <td><strong>Död</strong></td>
                            <td>@($"† {person.DeathDate}")</td>
                        </tr>
                    }
                    <tr>
                        @if (baptism != null)
                        {
                            <td><strong>Döpt</strong></td>
                            <td>@baptism.BaptismDate</td>
                        }
                    </tr>
                </tbody>
            </table>

            <div class="person-card-details-link">
                <a href="" @onclick="OpenPersonDetailsModal" @onclick:preventDefault="true">Visa persondetaljer</a>
            </div>
        </div>

        @if (showPersonDetailsModal)
        {
            <div class="person-modal-backdrop" @onclick="ClosePersonDetailsModal">
                <div class="person-modal" role="dialog" aria-modal="true" aria-labelledby="person-details-modal-title" @onclick:stopPropagation="true">
                    <div class="person-modal-header">
                        <h5 id="person-details-modal-title" class="mb-0">Detaljer för @person.FirstName @person.SurName</h5>
                        <button type="button" class="btn-close" aria-label="Stang" @onclick="ClosePersonDetailsModal"></button>
                    </div>
                    <div class="person-modal-body">
                        <PersonDetails Id="Id" OnPhotoUpdated="HandlePersonDetailsPhotoUpdated" />
                    </div>
                </div>
            </div>
        }
    </div>
}
