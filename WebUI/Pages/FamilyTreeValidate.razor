@page "/tree/validate"
@page "/tree/validate/{RootId:long}"

@using DataSetService
@using DataSetService.FamilyTree
@using DataSetService.Models
@using Microsoft.AspNetCore.Components.Forms
@inject NavigationManager Navigation
@inject PersonService PersonService
@inject FamilyTreeService FamilyTreeService

<h3>Validering: Blazor-träd vs MVC</h3>

<p class="text-muted">
    Jämför nya <code>FamilyTreeService</code> mot legacy-logiken i <code>PersonService.BuildFamilyTree</code> (motsvarar MVC <code>GetFamilyTreeData</code>).
</p>

<div class="mb-3 d-flex flex-wrap align-items-end gap-2">
    <div style="min-width: 280px;">
        <label class="form-label">Rotperson</label>
        <InputSelect class="form-select" @bind-Value="selectedRootId">
            @if (persons is not null)
            {
                @foreach (var p in persons)
                {
                    <option value="@p.Id">@p.SurName @p.FirstName (@p.Id)</option>
                }
            }
        </InputSelect>
    </div>
    <button class="btn btn-primary" @onclick="Run">Kör validering</button>
</div>

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}

@if (report is not null)
{
    <div class="card mb-3" style="max-width: 900px;">
        <div class="card-body">
            <h5 class="card-title">Sammanfattning</h5>
            <div>RootId: <strong>@report.RootId</strong> (@FormatName(report.RootId))</div>
            <div>Legacy (MVC) unique persons (inkl spouse): <strong>@report.LegacyPersonCount</strong></div>
            <div>Ny (Blazor) unique persons: <strong>@report.NewPersonCount</strong></div>
            <div>Missing i ny: <strong>@report.MissingInNew.Count</strong></div>
            <div>Extra i ny: <strong>@report.ExtraInNew.Count</strong></div>
            <div class="mt-2">Spouse-relations verifierade: <strong>@report.SpouseRelationsVerified</strong> / @report.SpouseRelationsTotal</div>
            <div>Child-relations verifierade: <strong>@report.ChildRelationsVerified</strong> / @report.ChildRelationsTotal</div>
        </div>
    </div>

    @if (report.MissingInNew.Count > 0)
    {
        <h5>Missing i ny (första @MaxList)</h5>
        <ul>
            @foreach (var id in report.MissingInNew.Take(MaxList))
            {
                <li>@id — @FormatName(id)</li>
            }
        </ul>
    }

    @if (report.ExtraInNew.Count > 0)
    {
        <h5>Extra i ny (första @MaxList)</h5>
        <ul>
            @foreach (var id in report.ExtraInNew.Take(MaxList))
            {
                <li>@id — @FormatName(id)</li>
            }
        </ul>
    }
}

@code {
    private const int MaxList = 50;

    [Parameter] public long RootId { get; set; }

    private List<Person>? persons;
    private Dictionary<long, Person>? personById;
    private long selectedRootId;
    private string? error;
    private ValidationReport? report;

    protected override Task OnInitializedAsync()
    {
        persons = PersonService.GetAllPersons();
        persons = persons.OrderBy(p => p.SurName).ThenBy(p => p.FirstName).ThenBy(p => p.Id).ToList();
        personById = persons.ToDictionary(p => p.Id, p => p);

        selectedRootId = RootId > 0 ? RootId : (persons.FirstOrDefault()?.Id ?? 0);
        if (RootId > 0)
            RunValidation(RootId);

        return Task.CompletedTask;
    }

    private void Run()
    {
        if (selectedRootId <= 0)
            return;

        Navigation.NavigateTo($"/tree/validate/{selectedRootId}");
    }

    private void RunValidation(long rootId)
    {
        error = null;
        report = null;

        FamilyTreeDto newTree;
        List<Person> legacy;
        try
        {
            var buildOptions = new FamilyTreeBuildOptions
            {
                MaxDepth = 6,
                MaxNodes = 400,
                OnlyExpandChildrenWithFamilies = true
            };
            var layoutOptions = new FamilyTreeLayoutOptions();
            newTree = FamilyTreeService.BuildTree(rootId, buildOptions, layoutOptions);

            legacy = PersonService.BuildFamilyTree(rootId);
        }
        catch (Exception ex)
        {
            error = ex.Message;
            return;
        }

        var newPersons = newTree.Nodes
            .Where(n => string.Equals(n.Type, "person", StringComparison.OrdinalIgnoreCase) && n.PersonId is not null)
            .Select(n => n.PersonId!.Value)
            .ToHashSet();

        var legacyPersons = new HashSet<long>();
        foreach (var p in legacy)
        {
            legacyPersons.Add(p.Id);
            if (p.Spouse?.Id is long sid)
                legacyPersons.Add(sid);
        }

        var missing = legacyPersons.Except(newPersons).OrderBy(id => id).ToList();
        var extra = newPersons.Except(legacyPersons).OrderBy(id => id).ToList();

        // Build edge lookup from new tree
        var spouseEdges = newTree.Edges
            .Where(e => string.Equals(e.Type, "spouse", StringComparison.OrdinalIgnoreCase))
            .Select(e => (e.FromId, e.ToId))
            .ToHashSet(StringTupleComparer.Ordinal);

        var childEdges = newTree.Edges
            .Where(e => string.Equals(e.Type, "child", StringComparison.OrdinalIgnoreCase))
            .Select(e => (e.FromId, e.ToId))
            .ToHashSet(StringTupleComparer.Ordinal);

        // Validate spouse relations: for each legacy person with spouse + family, ensure both have spouse-edge to union
        int spouseTotal = 0;
        int spouseVerified = 0;
        foreach (var p in legacy)
        {
            if (p.Spouse is null || p.IsSpouseInFamily is null)
                continue;

            var familyId = p.IsSpouseInFamily.Value;
            var unionId = $"u:{familyId}";
            var pId = $"p:{p.Id}";
            var sId = $"p:{p.Spouse.Id}";

            spouseTotal++;
            if (spouseEdges.Contains((pId, unionId)) && spouseEdges.Contains((sId, unionId)))
                spouseVerified++;
        }

        // Validate child relations: for each legacy person with RootId (manager), ensure there exists a union such that parent->union spouse and union->child child
        // We scan all unions where parent has spouse-edge, then check child-edge.
        var unionsByParent = spouseEdges
            .GroupBy(e => e.Item1, e => e.Item2, StringComparer.Ordinal)
            .ToDictionary(g => g.Key, g => g.ToHashSet(StringComparer.Ordinal), StringComparer.Ordinal);

        int childTotal = 0;
        int childVerified = 0;
        foreach (var child in legacy)
        {
            if (child.RootId is null)
                continue;

            childTotal++;
            var parentNodeId = $"p:{child.RootId.Value}";
            if (!unionsByParent.TryGetValue(parentNodeId, out var unions))
                continue;

            var childNodeId = $"p:{child.Id}";
            bool ok = unions.Any(u => childEdges.Contains((u, childNodeId)));
            if (ok)
                childVerified++;
        }

        report = new ValidationReport(
            RootId: rootId,
            LegacyPersonCount: legacyPersons.Count,
            NewPersonCount: newPersons.Count,
            MissingInNew: missing,
            ExtraInNew: extra,
            SpouseRelationsTotal: spouseTotal,
            SpouseRelationsVerified: spouseVerified,
            ChildRelationsTotal: childTotal,
            ChildRelationsVerified: childVerified);
    }

    private string FormatName(long id)
    {
        if (personById is null)
            return string.Empty;

        if (!personById.TryGetValue(id, out var p))
            return "(okänd)";

        return ($"{p.SurName} {p.FirstName}").Trim();
    }

    private sealed record ValidationReport(
        long RootId,
        int LegacyPersonCount,
        int NewPersonCount,
        IReadOnlyList<long> MissingInNew,
        IReadOnlyList<long> ExtraInNew,
        int SpouseRelationsTotal,
        int SpouseRelationsVerified,
        int ChildRelationsTotal,
        int ChildRelationsVerified);

    private sealed class StringTupleComparer : IEqualityComparer<(string, string)>
    {
        public static readonly StringTupleComparer Ordinal = new();

        public bool Equals((string, string) x, (string, string) y)
            => string.Equals(x.Item1, y.Item1, StringComparison.Ordinal) && string.Equals(x.Item2, y.Item2, StringComparison.Ordinal);

        public int GetHashCode((string, string) obj)
            => HashCode.Combine(StringComparer.Ordinal.GetHashCode(obj.Item1), StringComparer.Ordinal.GetHashCode(obj.Item2));
    }
}
